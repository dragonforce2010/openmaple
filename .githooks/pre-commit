#!/bin/sh
# Anti-monolith gate. Lints staged TS/TSX so the 400-line cap (eslint max-lines = error)
# blocks oversized files before they enter the repo. Complexity / depth / function-length
# are warnings and do NOT block. Applies to every committer — Claude, Codex, Cursor, or
# hand edits — because it runs at the git layer, not inside any one AI tool.
#
# Enabled via `git config core.hooksPath .githooks` (the package.json "prepare" script
# does this on install). Bypass a single commit with `git commit --no-verify`.
staged=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^(apps|packages)/.*\.(ts|tsx)$')
[ -z "$staged" ] && exit 0
echo "$staged" | tr '\n' '\0' | xargs -0 bunx eslint
