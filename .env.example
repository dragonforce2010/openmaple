# Minimal local Docker settings.
# `scripts/setup-local-docker.sh` creates `.env.local` automatically; copy this
# file only when you want to override ports, database password, or model keys.

# Web/API ports exposed on the host.
MAPLE_WEB_PORT=8080
MAPLE_API_PORT=27951
MAPLE_MYSQL_HOST_PORT=3307
MAPLE_WEB_BASE_URL=http://127.0.0.1:8080

# Local MySQL container settings.
MAPLE_MYSQL_DATABASE=maple
MAPLE_MYSQL_USER=root
MAPLE_MYSQL_PASSWORD=maple

# Local Docker runtime/sandbox defaults.
MAPLE_LOCAL_DOCKER_MODE=true
MAPLE_AGENT_RUNTIME_PROVIDER=local_docker
MAPLE_SANDBOX_PROVIDER=local_docker
MAPLE_DOCKER_IMAGE=node:22-bookworm
MAPLE_DEV_LOGIN=true
MAPLE_DEV_API_KEY=maple_dev_key
MAPLE_LOCAL_MODEL_CONFIG_FILE=config/local-model.json
MAPLE_SEED_DEMO_DATA=false

# Required when OpenMaple runs in a container and controls the host Docker daemon.
# The setup script fills this with an absolute path under this repo.
MAPLE_DOCKER_WORKSPACE_HOST_ROOT=

# Optional. Leave empty for UI/onboarding evaluation. To show a model pool, copy
# `config/local-model.example.json` to `config/local-model.json` and point
# `api_key_env` at OPENAI_API_KEY or ARK_API_KEY. These MAPLE_LOCAL_* values
# are mapped into container envs without reading your host shell secrets.
MAPLE_LOCAL_OPENAI_API_KEY=
MAPLE_LOCAL_ARK_API_KEY=
MAPLE_LOCAL_OPENAI_BASE_URL=
MAPLE_LOCAL_OPENAI_MODEL=
MAPLE_LOCAL_ARK_MODEL=
