# Provider credentials. Set either OPENAI_API_KEY or ARK_API_KEY.
OPENAI_API_KEY=
ARK_API_KEY=

# Optional OpenAI-compatible provider settings.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
ARK_MODEL=doubao-seed-1-6-251015

# Persistent database. Maple uses MySQL as the product data source.
MAPLE_MYSQL_HOST=127.0.0.1
MAPLE_VEFAAS_BACKEND_MYSQL_HOST=
MAPLE_MYSQL_PORT=3306
MAPLE_MYSQL_DATABASE=maple
MAPLE_MYSQL_USER=root
MAPLE_MYSQL_PASSWORD=

# Object storage for uploads and generated artifacts. AK/SK comes from
# VOLCENGINE_ACCESS_KEY / VOLCENGINE_SECRET_KEY below.
MAPLE_TOS_BUCKET=
MAPLE_TOS_ENDPOINT=
MAPLE_TOS_REGION=cn-beijing
MAPLE_TOS_PUBLIC_BASE_URL=

# Tenant sandbox/runtime credentials are provided during tenant onboarding.
# Do not keep E2B API keys, veFaaS invoke URLs, function IDs, or runtime API keys
# in the repo-level .env.

# Public web origin used in OAuth redirects and tenant sign-in links.
MAPLE_WEB_BASE_URL=http://localhost:5173
# Optional override when the tenant sign-in link should use a different origin.
MAPLE_CONSOLE_BASE_URL=

# Optional Volcengine control-plane credentials for one-time runtime template provisioning.
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
MAPLE_VEFAAS_REGION=cn-beijing
MAPLE_VEFAAS_APP_NAME=
MAPLE_VEFAAS_REUSE_EXISTING=false
MAPLE_VEFAAS_BACKEND_VPC_ID=
MAPLE_VEFAAS_BACKEND_SUBNET_IDS=
MAPLE_VEFAAS_BACKEND_SECURITY_GROUP_IDS=
MAPLE_VEFAAS_BACKEND_ENABLE_SHARED_INTERNET_ACCESS=true
MAPLE_MYSQL_HELPER_TIMEOUT_MS=15000
MAPLE_AGENT_LOOP_INSTALL_POLICY=check
MAPLE_CLAUDE_CODE_PROTOCOL=claude_sdk_ndjson
MAPLE_CLAUDE_AGENT_SDK_PYTHON=python3
MAPLE_CLAUDE_AGENT_SDK_RUNNER_COMMAND=
MAPLE_CLAUDE_CODE_VERSION=latest
MAPLE_CODEX_VERSION=latest
# Override when the function image/layer installs CLIs at non-standard paths.
MAPLE_CLAUDE_CODE_COMMAND=
MAPLE_CODEX_COMMAND=

# Authentication and SSO provider discovery.
MAPLE_AUTH_SESSION_DAYS=7
MAPLE_COOKIE_SECURE=false
MAPLE_DEV_API_KEY=maple_dev_key
MAPLE_DEV_USER_EMAIL=local-managed-agent@example.com
MAPLE_DEV_USER_NAME=Maple Developer
MAPLE_OAUTH_AUTHORIZE_URL=
MAPLE_OAUTH_TOKEN_URL=
MAPLE_OAUTH_USERINFO_URL=
MAPLE_OAUTH_CLIENT_ID=
MAPLE_OAUTH_CLIENT_SECRET=
MAPLE_OAUTH_SCOPE=email profile
MAPLE_OIDC_AUTHORIZE_URL=
MAPLE_OIDC_TOKEN_URL=
MAPLE_OIDC_USERINFO_URL=
MAPLE_OIDC_CLIENT_ID=
MAPLE_OIDC_CLIENT_SECRET=
MAPLE_OIDC_SCOPE=openid email profile
# Lark/enterprise OIDC SSO. When MAPLE_LARK_TOKEN_URL is set, Maple treats
# MAPLE_LARK_* as a generic OIDC provider and uses MAPLE_LARK_CALLBACK_URL for
# both start and callback redirect_uri.
MAPLE_LARK_TOKEN_URL=
MAPLE_LARK_CLIENT_ID=
MAPLE_LARK_CLIENT_SECRET=
MAPLE_LARK_CALLBACK_URL=http://localhost:5173/v1/auth/oauth/lark_sso/callback
# Legacy Lark OpenAPI SSO fallback. Leave MAPLE_LARK_TOKEN_URL empty to use it.
MAPLE_LARK_OPENAPI_BASE_URL=https://open.feishu.cn/open-apis
MAPLE_LARK_AUTHORIZE_URL=https://accounts.feishu.cn/open-apis/authen/v1/authorize
MAPLE_LARK_APP_ACCESS_TOKEN_URL=
MAPLE_LARK_USER_ACCESS_TOKEN_URL=
MAPLE_LARK_USERINFO_URL=
MAPLE_LARK_APP_ID=
MAPLE_LARK_APP_SECRET=
MAPLE_LARK_SCOPE=auth:user.id:read
MAPLE_BYTESSO_AUTHORIZE_URL=
MAPLE_BYTESSO_TOKEN_URL=
MAPLE_BYTESSO_USERINFO_URL=
MAPLE_BYTESSO_CLIENT_ID=
MAPLE_BYTESSO_CLIENT_SECRET=
MAPLE_BYTESSO_SCOPE=email profile

# ── Preset MCP provider OAuth clients ──
# Platform-managed OAuth client credentials per catalog provider (see catalog/mcpCatalog.ts).
# A provider shows as "enabled" in the vault/MCP picker only when its _CLIENT_ID is set.
# Without these, /v1/mcp_catalog returns configured:false and OAuth start fails with oauth_client_not_configured.
MAPLE_MCP_GITHUB_CLIENT_ID=
MAPLE_MCP_GITHUB_CLIENT_SECRET=
MAPLE_MCP_NOTION_CLIENT_ID=
MAPLE_MCP_NOTION_CLIENT_SECRET=
# MAPLE_MCP_VERCEL_*, MAPLE_MCP_GOOGLE_*, MAPLE_MCP_CANVA_*, MAPLE_MCP_FIGMA_*, MAPLE_MCP_ATLASSIAN_* follow the same _CLIENT_ID / _CLIENT_SECRET pattern.

# Public base URL of the control plane API, used to build the MCP OAuth redirect_uri
# (<base>/v1/mcp/oauth/callback). Must match the redirect URI registered on the provider's OAuth app.
# Falls back to the request protocol+host when unset (localhost in dev — usually NOT what the provider expects).
MAPLE_CONTROL_PLANE_BASE_URL=

# Base64 32-byte master key for the secret store (AES-256-GCM). Set this on hosts with a
# non-persistent secretsDir (veFaaS /tmp) so encrypted credentials survive restarts. When unset,
# a local file key is generated under <dataDir>/secrets/master.key. Generate: openssl rand -base64 32
MAPLE_SECRET_MASTER_KEY=

# Host port exposed by Docker Compose.
MAPLE_PORT=27951

# Required when the app runs in a container and controls the host Docker daemon.
# Use an absolute host path that corresponds to the bind-mounted session folder.
# Example:
# MAPLE_DOCKER_WORKSPACE_HOST_ROOT=/Users/you/workspace/managed-agents-platform/.managed-agents/sessions
MAPLE_DOCKER_WORKSPACE_HOST_ROOT=
